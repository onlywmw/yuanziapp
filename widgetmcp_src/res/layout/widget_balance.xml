<?xml version="1.0" encoding="utf-8"?>
<!-- 4x1 DeepSeek 余额 — 暖纸 Warm Paper · 白玻璃 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root_click_area"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/widget_bg_glass"
    android:padding="14dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="DeepSeek 余额" android:textColor="#8C8378" android:textSize="11sp"/>
        <TextView android:id="@+id/balance_amount" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:layout_marginTop="2dp"
            android:text="¥ --" android:textColor="#2E2A26"
            android:textSize="26sp" android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="end">
        <TextView android:id="@+id/balance_status" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="未配置" android:textColor="#9C7326"
            android:textSize="10sp" android:textStyle="bold" android:background="@drawable/chip_amber"
            android:paddingLeft="10dp" android:paddingRight="10dp"
            android:paddingTop="3dp" android:paddingBottom="3dp"/>
        <TextView android:id="@+id/balance_updated" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:layout_marginTop="4dp"
            android:text="更新于 --:--" android:textColor="#B4AB9E" android:textSize="10sp"/>
    </LinearLayout>
</LinearLayout>
